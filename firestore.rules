rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId);
    }
    
    // 2. Admins Collection
    match /admins/{userId} {
      allow read: if isAdmin();
      allow write: if false; // Only manageable via console
    }
    
    // 3. Products Collection
    match /products/{productId} {
      allow read: if true; 
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn(); 
    }
    
    // 4. Orders Collection
    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.farmerId == request.auth.uid || isAdmin());
      allow list: if isSignedIn(); // Queries must be filtered by userId or farmerId
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.farmerId == request.auth.uid || isAdmin());
    }
    
    // 5. Predictions Collection
    match /predictions/{predictionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }
    
    // 6. Test Collection for health check
    match /test/{docId} {
      allow read: if true; 
    }
  }
}
