rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. User Profiles
    function isValidUser(data) {
      return data.uid is string && 
             data.email is string && 
             data.role in ['farmer', 'consumer', 'admin'] &&
             data.keys().hasAll(['uid', 'email', 'role']) &&
             data.keys().size() <= 10; // Allow some growth
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId;
      allow update: if (isOwner(userId) && isValidUser(incoming()) && incoming().role == existing().role) || isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.token.email == "aswinjoel04@gmail.com" && adminId == request.auth.uid;
    }

    // 4. Products (Marketplace)
    function isValidProduct(data) {
      return data.farmerId is string && 
             data.name is string && 
             data.price is number && 
             data.category is string &&
             data.farmerId == request.auth.uid;
    }

    match /products/{productId} {
      allow read: if true; // Public listings
      allow create: if isSignedIn() && isValidProduct(incoming());
      allow update: if isSignedIn() && existing().farmerId == request.auth.uid && isValidProduct(incoming());
      allow delete: if isSignedIn() && existing().farmerId == request.auth.uid;
    }

    // 5. Orders
    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.consumerId == request.auth.uid || resource.data.farmerId == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.consumerId == request.auth.uid || resource.data.farmerId == request.auth.uid);
      allow create: if isSignedIn() && incoming().consumerId == request.auth.uid;
      allow update: if isSignedIn() && (existing().consumerId == request.auth.uid || existing().farmerId == request.auth.uid);
    }

    // 6. Predictions
    match /predictions/{predictionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }
  }
}
