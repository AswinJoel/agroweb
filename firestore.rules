rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    
    // Users
    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Admins
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.consumerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // Connection Test
    match /test/connection {
      allow read: if true;
    }

    // Predictions
    match /predictions/{predictionId} {
      allow read, write: if isSignedIn();
    }
  }
}
